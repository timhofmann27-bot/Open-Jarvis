# Open-Jarvis environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it's gitignored

# ── Required ─────────────────────────────────────────────────────
# Get one from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ── Optional: Local LLM ─────────────────────────────────────────
# Path to your Ollama instance
OLLAMA_HOST=http://localhost:11434
# Default model to use in local mode
# Options: tinyllama (700MB), phi3:mini (2.2GB), llama3.2:3b (2GB)
OLLAMA_MODEL=tinyllama
# Force local mode (skip Gemini entirely)
JARVIS_LOCAL_MODE=0

# ── Optional: Ports ─────────────────────────────────────────────
DASHBOARD_PORT=8080
TV_PORT=8765
OLLAMA_PORT=11434

# ── Optional: Timezone ──────────────────────────────────────────
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Berlin

# ── Optional: Logging ───────────────────────────────────────────
LOG_LEVEL=INFO

# ── Optional: Proactive features ────────────────────────────────
JARVIS_PROACTIVE_ENABLED=0

# ── Optional: Self-modification (security) ──────────────────────
# When 1, requires explicit approval for self-modification
JARVIS_SELF_MODIFY_REQUIRE_APPROVAL=0
